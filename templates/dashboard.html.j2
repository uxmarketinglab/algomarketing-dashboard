<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Community Pulse · {{ week_label }}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            teal:     { DEFAULT: '#0D9488', light: '#CCFBF1', dark: '#0F766E' },
            offwhite: '#F5F5F0',
            ink:      '#1C1917',
          },
          fontFamily: {
            serif: ['"DM Serif Display"', 'Georgia', 'serif'],
            sans:  ['"Inter"', 'system-ui', 'sans-serif'],
          },
        },
      },
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
  <style>
    body { background-color: #F5F5F0; color: #1C1917; }
  </style>
</head>
<body class="font-sans min-h-screen">

  <!-- ── Masthead ─────────────────────────────────────────────────────────── -->
  <header class="max-w-2xl mx-auto px-6 pt-12 pb-8">

    <!-- Top rule -->
    <div class="flex items-center gap-3 mb-6">
      <div class="h-px flex-1 bg-stone-300"></div>
      <span class="text-[10px] font-semibold uppercase tracking-[0.25em] text-stone-400">Algomarketing</span>
      <div class="h-px flex-1 bg-stone-300"></div>
    </div>

    <!-- Title + byline -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
      <div>
        <h1 class="font-serif text-5xl text-ink leading-none tracking-tight">Community<br/>Pulse</h1>
        <p id="tagline"
           class="mt-3 text-[10px] font-semibold uppercase tracking-[0.25em] text-teal"
           style="transition: opacity 0.5s ease;">Built in Lisbon · Q1 2026</p>
      </div>
      <div class="text-right leading-snug">
        <p class="text-sm font-semibold text-ink">Christina Waterman</p>
        <p class="text-sm text-stone-500">Week of {{ week_label }}</p>
      </div>
    </div>
    <script>
      (function () {
        var phrases = [
          "Built in Lisbon · Q1 2026",
          "Algomarketing Centre of Evolution",
          "Community & Workforce Development"
        ];
        var idx = 0;
        var el = document.getElementById('tagline');
        setInterval(function () {
          el.style.opacity = '0';
          setTimeout(function () {
            idx = (idx + 1) % phrases.length;
            el.textContent = phrases[idx];
            el.style.opacity = '1';
          }, 500);
        }, 3000);
      })();
    </script>

    <!-- Editor's note -->
    {% if editors_note %}
    <p class="mt-6 font-serif italic text-stone-500 text-base leading-relaxed border-l-[3px] border-teal pl-4">
      {{ editors_note }}
    </p>
    {% endif %}

    <!-- Bottom rule -->
    <div class="mt-8 h-px bg-stone-300"></div>
  </header>

  <main class="max-w-2xl mx-auto px-6 pb-20">

    <!-- ── Community Engagement Score ───────────────────────────────────────── -->
    <section class="text-center py-16">
      <p class="text-[10px] font-semibold uppercase tracking-[0.25em] text-stone-400 mb-8">
        Community Pulse Score
      </p>

      <!-- The number — magazine cover style -->
      <div class="flex items-start justify-center gap-2">
        <span class="font-serif leading-none text-teal" style="font-size: clamp(6rem, 20vw, 10rem);">{{ score.score }}</span>
        <div class="pt-5 text-left">
          <span class="text-xl text-stone-300 font-light">/100</span>
          <div class="mt-2">
            {% if score.baseline %}
            <span class="text-sm text-stone-400">Week 1 baseline</span>
            {% elif score.trend == 'up' %}
            <span class="text-sm font-semibold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-full">↑ {{ score.delta }} pts</span>
            {% elif score.trend == 'down' %}
            <span class="text-sm font-semibold text-rose-500 bg-rose-50 px-2 py-0.5 rounded-full">↓ {{ score.delta }} pts</span>
            {% else %}
            <span class="text-sm text-stone-400">→ steady</span>
            {% endif %}
          </div>
        </div>
      </div>

      <!-- Score breakdown — minimal stat row -->
      <div class="mt-10 flex flex-wrap justify-center gap-x-5 gap-y-3 text-xs text-stone-400">
        <span>Community Impact &nbsp;<strong class="text-ink font-semibold">{{ score.breakdown.community_impact }}/40</strong></span>
        <span class="text-stone-300">·</span>
        <span>Program Delivery &nbsp;<strong class="text-ink font-semibold">{{ score.breakdown.program_delivery }}/35</strong></span>
        <span class="text-stone-300">·</span>
        <span>Strategic Focus &nbsp;<strong class="text-ink font-semibold">{{ score.breakdown.scope_health }}/25</strong></span>
      </div>

      <!-- Score description -->
      <p class="mt-6 text-xs text-stone-400 max-w-md mx-auto leading-relaxed">
        A weekly index measuring community impact (events and activations), program delivery (tasks completed), and strategic focus (time spent on what matters most) — tracked over time.
      </p>
    </section>

    <!-- ── What We Built ─────────────────────────────────────────────────── -->
    <section class="border-t border-stone-200 pt-14 pb-4">
      <div class="flex items-baseline gap-3 mb-2">
        <h2 class="font-serif text-4xl text-ink">What We Built</h2>
        <div class="h-px flex-1 bg-stone-200 mt-1"></div>
      </div>
      <p class="text-xs italic text-stone-400 mb-8">Week of {{ week_label }}</p>

      {% if wins %}
      <div class="space-y-5">
        {% for win in wins %}
        {% set parts = win.split(': ', 1) %}
        <div class="pb-5 border-b border-stone-100 last:border-b-0 last:pb-0">
          {% if parts|length > 1 %}
          <h3 class="font-serif text-2xl text-teal leading-tight mb-2">{{ parts[0] }}</h3>
          <p class="text-stone-600 leading-relaxed text-[15px]">{{ parts[1] }}</p>
          {% else %}
          <p class="text-stone-600 leading-relaxed text-[15px]">{{ win }}</p>
          {% endif %}
        </div>
        {% endfor %}
      </div>
      {% else %}
      <p class="text-stone-400 italic text-sm">
        Connect Asana to pull completed tasks automatically — add credentials to your <code class="font-mono text-xs">.env</code> file.
      </p>
      {% endif %}

      <!-- Weekly Wins & Key Actions -->
      {% if links %}
      <div class="mt-12">
        <div class="flex items-baseline gap-3 mb-4">
          <h3 class="font-serif text-3xl text-ink">Weekly Wins &amp; Key Actions</h3>
          <div class="h-px flex-1 bg-stone-200 mt-1"></div>
        </div>
        <ul class="space-y-2">
          {% for link in links %}
          <li>
            <a href="{{ link.url }}" target="_blank" rel="noopener"
               class="text-teal font-medium hover:underline text-[15px]">→ {{ link.label }}</a>
          </li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}

      <!-- Expanding Influence -->
      {% if scope_evolution %}
      <div class="mt-14">
        <p class="text-[10px] uppercase tracking-[0.2em] text-stone-400 mb-6">Expanding Influence</p>
        <ol class="space-y-5">
          {% for item in scope_evolution %}
          <li class="flex items-start gap-5">
            <span class="font-serif text-teal text-xl leading-tight w-5 flex-shrink-0 select-none">{{ loop.index }}</span>
            <span class="text-stone-600 leading-relaxed text-[15px]">{{ item }}</span>
          </li>
          {% endfor %}
        </ol>
      </div>
      {% endif %}
    </section>

    <!-- ── What I Need ───────────────────────────────────────────────────── -->
    <section class="border-t border-stone-200 pt-14 pb-4 mt-14">
      <div class="flex items-baseline gap-3 mb-8">
        <h2 class="font-serif text-4xl text-ink">What I Need</h2>
        <div class="h-px flex-1 bg-stone-200 mt-1"></div>
      </div>

      {% if what_i_need %}
      <ol class="space-y-5">
        {% for item in what_i_need %}
        <li class="flex items-start gap-5">
          <span class="font-serif text-teal text-xl leading-tight w-5 flex-shrink-0 select-none">{{ loop.index }}</span>
          <span class="text-stone-600 leading-relaxed text-[15px]">{{ item }}</span>
        </li>
        {% endfor %}
      </ol>
      {% else %}
      <p class="text-stone-400 italic text-sm">Nothing blocking this week.</p>
      {% endif %}
    </section>

    <!-- ── The Room's Energy ────────────────────────────────────────────────── -->
    <section class="border-t border-stone-200 pt-14 mt-14">
      <div class="flex items-baseline gap-3 mb-6">
        <h2 class="font-serif text-4xl text-ink">The Room's Energy</h2>
        <div class="h-px flex-1 bg-stone-200 mt-1"></div>
      </div>

      <p class="text-stone-600 leading-relaxed text-[15px] max-w-xl">{{ culture_pulse }}</p>
    </section>

  </main>

  <!-- ── Download button ────────────────────────────────────────────────────── -->
  <div class="max-w-2xl mx-auto px-6 pt-10 pb-2 text-center">
    <button onclick="window.print()"
      class="text-[11px] font-semibold uppercase tracking-[0.15em] text-teal border border-teal px-4 py-1.5 rounded hover:bg-teal hover:text-white transition-colors">
      Download Report
    </button>
  </div>

  <!-- ── Footer ─────────────────────────────────────────────────────────────── -->
  <footer class="max-w-2xl mx-auto px-6 py-8">
    <div class="h-px bg-stone-300 mb-4"></div>
    <div class="flex justify-between items-center text-[10px] uppercase tracking-[0.15em] text-stone-400">
      <span>Community Pulse · Christina Waterman</span>
      <span>{{ week_label }}</span>
    </div>
  </footer>

</body>
</html>
